#!/bin/bash
set -euo pipefail

# Update system

function log {
    echo -e "\033[1;34m$*\033[0m"
}

function main {
    local distribution

    distribution="$(lsb_release -a 2> /dev/null | awk '/^Distributor ID:/ { print $3 }')"

    case "${distribution}" in
        'Ubuntu')
            log Update
            sudo apt -y update

            log Upgrade
            sudo apt -y upgrade
            ;;
        'ManjaroLinux')
            log Upgrade
            sudo pacman -Syyu --noprogressbar --noconfirm
            log Clean cache
            sudo pacman -Sc --noconfirm
            ;;
        *)
            echo "Unknown distribution ${distribution}."
            exit 1
            ;;
    esac
}

# Ask password once at the begining
sudo true

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/up"
LOG_FILE="${LOG_DIR}/$(date '+%Y%m%d_%H%M%S')_upgrade.log"

[[ -d "$LOG_DIR" ]] || mkdir -pv "$LOG_DIR"

log Delete old log files
find "$LOG_DIR" -type f -name '*.log' -ctime +180 -delete

main > >(tee "${LOG_FILE}") 2>&1

log "System upgraded successfully! Log file saved in ${LOG_FILE}"
