#!/bin/bash
set -euo pipefail

# Update system

function log {
    echo -e "\033[1;34m$*\033[0m"
}

function ubuntu_up {
    date
    sudo true

    echo
    log Update
    sudo apt -y update

    echo
    log Upgrade
    sudo apt -y upgrade
}

function manjaro_up {
    log Manjaro Upgrade
    sudo pacman -Syyu --noprogressbar --noconfirm
}

LOG_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/up.log"
distribution="$(lsb_release -a 2> /dev/null | awk '/^Distributor ID:/ { print $3 }')"

case "${distribution}" in
    'Ubuntu')
        ubuntu_up > >(tee "${LOG_FILE}") 2>&1
        ;;
    'ManjaroLinux')
        manjaro_up > >(tee "${LOG_FILE}") 2>&1
        ;;
    *)
        echo "Unknown distribution ${distribution}."
        exit 1
        ;;
esac

echo -e "\nDone ! Log file saved in ${LOG_FILE}"
