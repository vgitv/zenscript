#!/bin/bash
set -euo pipefail

# Update system

function log {
    echo -e "\033[1;34m$*\033[0m"
}

function main {
    local distribution

    distribution="$(lsb_release -a 2> /dev/null | awk '/^Distributor ID:/ { print $3 }')"

    case "${distribution}" in
        'Ubuntu')
            local has_docker=n

            if systemctl status docker.service | grep -q 'Active: active'; then
                # Else Docker uses a TUI asking to stop docker processes, that freezes the terminal
                has_docker=y
                log Stop docker
                sudo systemctl stop docker.socket
                sudo systemctl stop docker.service
                echo Done
            fi

            log Update
            sudo apt-get -y --quiet update

            log Upgrade
            sudo apt-get -y --quiet upgrade

            if [[ "$has_docker" = 'y' ]]; then
                log Start docker
                sudo systemctl start docker.service
                sudo systemctl start docker.socket
                echo Done
            fi
            ;;
        'ManjaroLinux')
            log Upgrade
            sudo pacman -Syyu --noprogressbar --noconfirm
            log Clean cache
            sudo pacman -Sc --noconfirm
            ;;
        *)
            echo "Unknown distribution ${distribution}."
            exit 1
            ;;
    esac
}

# Ask password once at the begining
sudo true

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/up"
LOG_FILE="${LOG_DIR}/$(date '+%Y%m%d_%H%M%S')_upgrade.log"

[[ -d "$LOG_DIR" ]] || mkdir -pv "$LOG_DIR"

log Delete old log files
find "$LOG_DIR" -type f -name '*.log' -ctime +180 -delete
echo Done

main > >(tee "${LOG_FILE}") 2>&1

log "System upgraded successfully!"
echo "Log file saved in $(ls --hyperlink "${LOG_FILE}")"
