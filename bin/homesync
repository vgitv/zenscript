#!/bin/bash
set -euo pipefail

# DESCRIPTION - Backup home directory
# SYNOPSIS - homesync <external_disk_path>
# TEST - HOMESYNC_CUSTOM_HOME=/tmp/home homesync /tmp/save

# Backup target directory
TARGET="$1"


function log {
    local level="$1" && shift
    declare -A color
    color['info']='\033[1;32m'
    color['warning']='\033[1;33m'
    color['error']='\033[1;31m'
    echo -e "${color[$level]}$(date '+%Y-%m-%d %H:%M:%S') - ${level^^} - $*\033[0m"
}


log info 'Checks'

if [[ -n "${HOMESYNC_CUSTOM_HOME:-}" ]]; then
    log warning "test mode: custom home directory is set to ${HOMESYNC_CUSTOM_HOME}"
fi

# Source directories - Special variable can be used for test purpose
SOURCE_HOME="${HOMESYNC_CUSTOM_HOME:-$HOME}"
SOURCE_PICS="${HOMESYNC_CUSTOM_HOME:-$HOME}/Images"

# Destination backup directories
BACKUP_HOME="${TARGET}/BACKUP_HOME"
BACKUP_PICS="${TARGET}/BACKUP_PHOTOS"

if [[ ! -d "$TARGET" ]]; then
    log error "Target directory ${TARGET} should exist"
    exit 1
fi

echo "Available disk space on target: $(df --output=avail -h "$1" | tail -n 1 | grep -oP '[^ ]*')"

echo -e "> Sync ${SOURCE_HOME}/*\n  into ${BACKUP_HOME}"
echo -e "> Sync ${SOURCE_PICS}/*\n  into ${BACKUP_PICS}"

if [[ ! -d "$BACKUP_HOME" ]]; then
    log warning "Directory ${BACKUP_HOME} will be created"
fi

if [[ ! -d "$BACKUP_PICS" ]]; then
    log warning "Directory ${BACKUP_PICS} will be created"
fi

echo -n "Proceed? (y/n) "
read -r answer
if [[ ${answer} != 'y' ]]; then
    log error 'Cancel operations, nothing done'
    exit 1
fi

mkdir -pv "$BACKUP_HOME" "$BACKUP_PICS"


# Mirror backup - Source and target should match exactly
log info "Sync home"
rsync \
    --archive \
    --inplace \
    --human-readable \
    --info=progress2 \
    --exclude="/Images/" \
    --exclude="/Public/" \
    --exclude="/Téléchargements/" \
    --exclude="/Vidéos/" \
    --exclude=".git/" \
    --exclude="__pycache__/" \
    --exclude=".venv/" \
    --exclude="venv/" \
    --delete \
    "$SOURCE_HOME"/* \
    "$BACKUP_HOME"
echo 'Done'


# Source to destination backup - No deletion on the receiving side
log info "Sync pictures"
rsync \
    --archive \
    --inplace \
    --human-readable \
    --info=progress2 \
    "$SOURCE_PICS"/* \
    "$BACKUP_PICS"
echo 'Done'


log info 'All done!'
