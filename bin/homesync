#!/bin/bash
set -euo pipefail

# Backup target directory
TARGET="$1"


function log {
    local level="$1" && shift
    declare -A color
    color['info']='\033[1;32m'
    color['warning']='\033[1;33m'
    color['error']='\033[1;31m'
    echo -e "${color[$level]}$(date -Iminutes) - ${level^^} - $*\033[0m"
}


log info 'Checks'

if [[ -n "${HOMESYNC_CUSTOM_HOME:-}" ]]; then
    log warning "test mode: HOMESYNC_CUSTOM_HOME is set to ${HOMESYNC_CUSTOM_HOME}"
fi

# Source directories
# HOMESYNC_CUSTOM_HOME can be used for test purpose
SOURCE_HOME="${HOMESYNC_CUSTOM_HOME:-$HOME}"
SOURCE_PICS="${HOMESYNC_CUSTOM_HOME:-$HOME}/Images"

# Backup directories
BACKUP_HOME="${TARGET}/BACKUP_HOME"
BACKUP_PICS="${TARGET}/BACKUP_PHOTOS"

if [[ ! -d "$TARGET" ]]; then
    log error "Target directory ${TARGET} should exist"
    exit 1
fi

echo "Available disk space on target: $(df --output=avail -h "$1" | tail -n 1 | grep -oP '[^ ]*')"

echo -e "==> Sync ${SOURCE_HOME}\n    into ${BACKUP_HOME}"
echo -e "==> Sync ${SOURCE_PICS}\n    into ${BACKUP_PICS}"

if [[ ! -d "$BACKUP_HOME" ]]; then
    log warning "Directory ${BACKUP_HOME} will be created"
fi

if [[ ! -d "$BACKUP_PICS" ]]; then
    log warning "Directory ${BACKUP_PICS} will be created"
fi

echo -n "Proceed? (y/n) "
read -r answer
if [[ ${answer} != 'y' ]]; then
    log error 'Cancel operations - nothing done'
    exit 1
fi

mkdir -pv "$BACKUP_HOME" "$BACKUP_PICS"


log info "Sync home"

# Mirror backup - source and target should match exactly
# NB : les fichiers cachés à la racine du home ne seront pas pris en
# compte, en revanche les fichiers cachés dans les sous-dossier le seront.
rsync \
    --archive \
    --human-readable \
    --info=progress2 \
    --exclude="/Images/" \
    --exclude="/Public/" \
    --exclude="/Téléchargements/" \
    --exclude="/Vidéos/" \
    --exclude=".git/" \
    --exclude="__pycache__/" \
    --exclude=".venv/" \
    --exclude="venv/" \
    --delete \
    "$SOURCE_HOME"/* \
    "$BACKUP_HOME"
echo 'Done'


log info "Sync pictures"
# Synchronisation source vers cible. Pas de suppression sur la cible si le
# fichier n'existe plus sur la source. Cela permet de construire un album
# avec la totalité des photos sauvegardées sur différentes machines. Le
# dossier ~/Images ne doit donc contenir que des photos (stocker les autres
# images ailleurs).
rsync \
    --archive \
    --human-readable \
    --info=progress2 \
    "$SOURCE_PICS"/* \
    "$BACKUP_PICS"
echo 'Done'


log info 'All done!'
