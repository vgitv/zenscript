#!/bin/zsh
emulate -L zsh
setopt no_unset pipe_fail err_exit err_return warn_create_global

# Autocommit and push to repository, when commit description is not important.
# Usage:
# autocommit


typeset repo_path="$(git rev-parse --show-toplevel)"

if [[ ! -f "${repo_path}/.allow-autocommit" ]]; then
    print 'Autocommit not allowed on this repository.'
    print 'Create an empty file .allow-autocommit at the root of the repository if you want to allow it.'
    exit 1
fi

git add "$repo_path"

if git status --porcelain | grep -qE '.'; then
    git commit -m "Autocommit"
    git push
    print 'Commit pushed'
else
    print 'Nothing to do'
fi
