#!/bin/zsh
emulate -L zsh
setopt no_unset pipe_fail err_exit err_return warn_create_global

# Autocommit and push to repository, when commit description is not important.
# Usage:
# autocommit


if git remote -v | grep -vqE '(vmacp|vgitv)'; then
    print 'No autocommit if remote is not personnal account'
    exit 1
fi

git add "$(git rev-parse --show-toplevel)"

if git status --porcelain | grep -qE '.'; then
    git commit -m "Autocommit"
    git push
    print 'Commit pushed'
else
    print 'Nothing to do'
fi
